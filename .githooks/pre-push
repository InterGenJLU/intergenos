#!/usr/bin/env bash
# .githooks/pre-push — local gates before pushing to origin
#
# Catches issues that would otherwise need fix-commits after CI runs:
# - Public-content audit violations (agent abbrevs, hex-secret false positives, PII)
# - Bash syntax errors in modified .sh files
# - Python syntax errors in modified .py files
# - Stale local master (someone pushed while we worked → must rebase first)
#
# Active when scripts/setup-githooks.sh has been run (sets core.hooksPath=.githooks).
# Bypass for emergencies: git push --no-verify (use sparingly; flag in commit msg).

set -euo pipefail

REPO_ROOT=$(git rev-parse --show-toplevel)
cd "$REPO_ROOT"

echo "[pre-push] running local gates..."

# ---- 0. Working-tree-vs-HEAD coherence -----------------------------------
# The public-content audit (gate 1 below) reads files from the working tree
# via open(path). When the working tree differs from HEAD (uncommitted
# changes; soft-reset+edit-without-stage; etc.), the audit can pass on
# working-tree content while the actually-being-pushed content (HEAD)
# carries violations. Caught 2026-05-06: a soft-reset+edit pattern
# committed an unscrubbed agent-abbrev despite the audit passing.
#
# The fix: require working tree == HEAD before push. This guarantees the
# audit (which scans working-tree files) is scanning the same content
# that's about to be pushed. Cost: users with uncommitted unrelated
# changes must commit-or-stash first; that's an acceptable trade for
# the security-posture our public-content discipline requires.
if ! git diff HEAD --quiet 2>/dev/null; then
    echo "[pre-push] BLOCK: uncommitted changes detected (working tree differs from HEAD)."
    echo "  Reason: the public-content audit scans working-tree files; uncommitted"
    echo "  changes may mask violations in HEAD content (the actually-pushed bytes)."
    echo "  Inspect: git status / git diff HEAD"
    echo "  Resolve: commit the changes, OR git stash them, before retrying push."
    exit 1
fi

# ---- 1. Public-content audit ---------------------------------------------
if [ -f scripts/check-public-content.py ]; then
    if ! python3 scripts/check-public-content.py; then
        echo "[pre-push] BLOCK: public-content audit failed (see above)"
        exit 1
    fi
else
    echo "[pre-push] WARN: scripts/check-public-content.py not found; skipping audit"
fi

# ---- 2. Stale-master check ------------------------------------------------
# Fetch origin master; require local to be at-or-ahead of origin/master.
# This prevents the "DS pushed while I worked → my push rejected → fix" loop.
git fetch origin master --quiet 2>/dev/null || true

LOCAL=$(git rev-parse master 2>/dev/null || echo "")
REMOTE=$(git rev-parse origin/master 2>/dev/null || echo "")

if [ -n "$LOCAL" ] && [ -n "$REMOTE" ] && [ "$LOCAL" != "$REMOTE" ]; then
    BASE=$(git merge-base master origin/master 2>/dev/null || echo "")
    if [ "$BASE" = "$LOCAL" ]; then
        echo "[pre-push] BLOCK: local master is behind origin/master."
        echo "  Remote at: $REMOTE"
        echo "  Local at:  $LOCAL"
        echo "  Rebase: git pull --rebase origin master"
        exit 1
    elif [ -n "$BASE" ] && [ "$BASE" != "$REMOTE" ]; then
        echo "[pre-push] BLOCK: local and origin master have diverged."
        echo "  Resolve: git pull --rebase origin master (resolve conflicts)"
        exit 1
    fi
fi

# ---- 3. Syntax checks on modified files in to-be-pushed commits ---------
if [ -n "$LOCAL" ] && [ -n "$REMOTE" ] && [ "$LOCAL" != "$REMOTE" ]; then
    BASE=$(git merge-base "$LOCAL" "$REMOTE" 2>/dev/null || echo "$REMOTE")
    CHANGED=$(git diff --name-only --diff-filter=AM "$BASE" "$LOCAL" 2>/dev/null || true)

    # Bash syntax
    while IFS= read -r f; do
        [ -z "$f" ] && continue
        if [[ "$f" == *.sh ]] && [ -f "$f" ]; then
            if ! bash -n "$f" 2>/dev/null; then
                echo "[pre-push] BLOCK: bash syntax error in $f"
                bash -n "$f" || true
                exit 1
            fi
        fi
    done <<< "$CHANGED"

    # Python syntax (excludes virtualenv / __pycache__ / build dirs)
    while IFS= read -r f; do
        [ -z "$f" ] && continue
        if [[ "$f" == *.py ]] && [ -f "$f" ]; then
            case "$f" in
                */__pycache__/*|*/.venv/*|*/build/*) continue ;;
            esac
            if ! python3 -m py_compile "$f" 2>/dev/null; then
                echo "[pre-push] BLOCK: Python syntax error in $f"
                python3 -m py_compile "$f" || true
                exit 1
            fi
        fi
    done <<< "$CHANGED"
fi

echo "[pre-push] all gates PASS"
exit 0

#!/usr/bin/env bash
# .githooks/pre-push — local gates before pushing to origin
#
# Catches issues that would otherwise need fix-commits after CI runs:
# - Public-content audit violations (agent abbrevs, hex-secret false positives, PII)
# - Bash syntax errors in modified .sh files
# - Python syntax errors in modified .py files
# - Stale local master (someone pushed while we worked → must rebase first)
#
# Active when scripts/setup-githooks.sh has been run (sets core.hooksPath=.githooks).
# Bypass for emergencies: git push --no-verify (use sparingly; flag in commit msg).

set -euo pipefail

REPO_ROOT=$(git rev-parse --show-toplevel)
cd "$REPO_ROOT"

# ---- Python interpreter detection (host-portable) ------------------------
# Python invocation is portable across hosts:
#   - Linux/macOS:    python3 (typical)
#   - Windows mingw:  py launcher (Windows installer adds this)
#   - Windows fallback: python (if Python 3 is the only python on PATH)
# The bare `python3` path on Windows often resolves to the MS Store install
# stub, which prompts an install + exits non-zero (caught 2026-05-06 via
# cross-host clone validation; py-compile gate at gate 3 hit the same trap
# again 2026-05-19 from a Windows clone). The detection chain routes around it.
# Computed ONCE at hook start and reused by all gates that need Python.
if python3 --version >/dev/null 2>&1; then
    PY_BIN=python3
elif command -v py >/dev/null 2>&1; then
    PY_BIN=py
elif python --version 2>&1 | grep -q "Python 3"; then
    PY_BIN=python
else
    PY_BIN=""
fi

# Read stdin (pre-push hook receives refs being pushed):
#   <local_ref> <local_sha> <remote_ref> <remote_sha>
# Captured into PUSH_REFS array so later gates can inspect for force-push to master.
PUSH_REFS=()
while IFS= read -r line; do
    [ -z "$line" ] && continue
    PUSH_REFS+=("$line")
done

echo "[pre-push] running local gates..."

# ---- 0. Force-push HARD-block on master ----------------------------------
# master is sacred. Any push where remote_sha (current origin) is not an
# ancestor of local_sha (about to be pushed) means we're rewriting history
# at master — that's only possible via --force or --force-with-lease.
# HARD BLOCK: we never rewrite published master history.
ZERO="0000000000000000000000000000000000000000"
for refline in "${PUSH_REFS[@]}"; do
    read -r local_ref local_sha remote_ref remote_sha <<< "$refline"
    if [ "$remote_ref" = "refs/heads/master" ] && [ "$remote_sha" != "$ZERO" ]; then
        if ! git merge-base --is-ancestor "$remote_sha" "$local_sha" 2>/dev/null; then
            echo "[pre-push] BLOCK: force-push to master detected."
            echo "  remote master at: $remote_sha"
            echo "  local master at:  $local_sha"
            echo "  remote is NOT an ancestor of local — this would rewrite published history."
            echo "  master is sacred; no force-push permitted."
            echo "  If you genuinely need history rewrite (e.g., post-incident scrub),"
            echo "  coordinate with all active agents first AND temporarily remove this gate."
            exit 1
        fi
    fi
done

# ---- 1. Public-content audit (scans HEAD via git-show, NOT working tree) -
# The audit must scan the actually-being-pushed bytes. Reading from the
# working tree (the historical default) was incorrect: a soft-reset+edit
# pattern could pass the audit on working-tree content while the bytes in
# HEAD (what actually gets pushed) carried violations. Caught 2026-05-06.
# Fix: --from-ref HEAD reads each file via `git show HEAD:<file>` so the
# audit operates on the same content that's about to be pushed.
#
# Uses PY_BIN computed at hook start (host-portable Python detection).
if [ -f scripts/check-public-content.py ]; then
    if [ -z "$PY_BIN" ]; then
        echo "[pre-push] WARN: no Python 3 interpreter found; skipping audit"
    else
        if ! "$PY_BIN" scripts/check-public-content.py --from-ref HEAD; then
            echo "[pre-push] BLOCK: public-content audit failed (see above)"
            exit 1
        fi
    fi
else
    echo "[pre-push] WARN: scripts/check-public-content.py not found; skipping audit"
fi

# ---- 2. Stale-master check ------------------------------------------------
# Fetch origin master; require local to be at-or-ahead of origin/master.
# This prevents the "remote moved while we worked → push rejected" loop.
#
# Fail-closed posture (per §6 C1 review): if git fetch fails (network, auth,
# remote unreachable), the stale-master check would silently run against a
# cached origin/master ref and might pass a stale-base push. Block instead,
# with an explicit override env var for genuinely-offline scenarios.
if ! git fetch origin master --quiet 2>/dev/null; then
    if [ "${GIT_PRE_PUSH_SKIP_FETCH:-0}" = "1" ]; then
        echo "[pre-push] WARN: git fetch failed; continuing with cached origin/master per GIT_PRE_PUSH_SKIP_FETCH=1 override."
    else
        echo "[pre-push] BLOCK: git fetch origin master failed."
        echo "  Stale-master check requires fresh origin/master — cannot run on cached refs."
        echo "  Investigate: network connectivity, GitHub auth, SSH agent state."
        echo "  Override (only when network is unreachable AND local is confirmed current):"
        echo "    GIT_PRE_PUSH_SKIP_FETCH=1 git push origin master"
        exit 1
    fi
fi

LOCAL=$(git rev-parse master 2>/dev/null || echo "")
REMOTE=$(git rev-parse origin/master 2>/dev/null || echo "")

if [ -n "$LOCAL" ] && [ -n "$REMOTE" ] && [ "$LOCAL" != "$REMOTE" ]; then
    BASE=$(git merge-base master origin/master 2>/dev/null || echo "")
    if [ "$BASE" = "$LOCAL" ]; then
        echo "[pre-push] BLOCK: local master is behind origin/master."
        echo "  Remote at: $REMOTE"
        echo "  Local at:  $LOCAL"
        echo "  Rebase: git pull --rebase origin master"
        exit 1
    elif [ -n "$BASE" ] && [ "$BASE" != "$REMOTE" ]; then
        echo "[pre-push] BLOCK: local and origin master have diverged."
        echo "  Resolve: git pull --rebase origin master (resolve conflicts)"
        exit 1
    fi
fi

# ---- 3. Syntax checks on modified files in to-be-pushed commits ---------
if [ -n "$LOCAL" ] && [ -n "$REMOTE" ] && [ "$LOCAL" != "$REMOTE" ]; then
    BASE=$(git merge-base "$LOCAL" "$REMOTE" 2>/dev/null || echo "$REMOTE")
    CHANGED=$(git diff --name-only --diff-filter=AM "$BASE" "$LOCAL" 2>/dev/null || true)

    # Bash syntax
    while IFS= read -r f; do
        [ -z "$f" ] && continue
        if [[ "$f" == *.sh ]] && [ -f "$f" ]; then
            if ! bash -n "$f" 2>/dev/null; then
                echo "[pre-push] BLOCK: bash syntax error in $f"
                bash -n "$f" || true
                exit 1
            fi
        fi
    done <<< "$CHANGED"

    # Python syntax (excludes virtualenv / __pycache__ / build dirs)
    while IFS= read -r f; do
        [ -z "$f" ] && continue
        if [[ "$f" == *.py ]] && [ -f "$f" ]; then
            case "$f" in
                */__pycache__/*|*/.venv/*|*/build/*) continue ;;
            esac
            if [ -z "$PY_BIN" ]; then
                echo "[pre-push] WARN: no Python 3 interpreter; cannot py-compile $f"
                continue
            fi
            if ! "$PY_BIN" -m py_compile "$f" 2>/dev/null; then
                echo "[pre-push] BLOCK: Python syntax error in $f"
                "$PY_BIN" -m py_compile "$f" || true
                exit 1
            fi
        fi
    done <<< "$CHANGED"
fi

# ---- 4. Commit-message-to-diff scope gate --------------------------------
# For each commit in the push range, files with >THRESHOLD lines changed
# must appear in the commit message body. Catches under-documented commits
# like 8fc25f5 (2026-05-06: shipped 138 lines of mirror-upload under a
# 1-line-tweak commit message). Three-lane fleet consensus on this gate.
# Override: `NO-GATE: <reason>` line anywhere in commit message body for
# legitimate bulk-mechanical changes (e.g., mass-rename, generated content).
THRESHOLD=50
if [ -n "$LOCAL" ] && [ -n "$REMOTE" ] && [ "$LOCAL" != "$REMOTE" ]; then
    BASE=$(git merge-base "$LOCAL" "$REMOTE" 2>/dev/null || echo "$REMOTE")

    for sha in $(git rev-list --no-merges --reverse "$BASE".."$LOCAL"); do
        msg=$(git log -1 --format=%B "$sha")

        # Skip if NO-GATE override is present
        if echo "$msg" | grep -qE '^NO-GATE:'; then
            continue
        fi

        # Iterate per-file with >THRESHOLD added+removed lines
        while IFS=$'\t' read -r added removed file; do
            [ -z "$file" ] && continue
            # Binary files: numstat shows "-" instead of numbers; skip
            [ "$added" = "-" ] && continue
            total=$((added + removed))
            if [ "$total" -gt "$THRESHOLD" ]; then
                base=$(basename "$file")
                if ! echo "$msg" | grep -qF "$file" && ! echo "$msg" | grep -qF "$base"; then
                    echo "[pre-push] BLOCK: commit $sha touches $file ($total lines changed) but message doesn't mention it."
                    echo "  Reason: under-documentation risk (>$THRESHOLD lines = significant scope; must appear in message)."
                    echo "  Resolve: amend message to reference $file, OR add 'NO-GATE: <reason>' line for legitimate bulk-mechanical changes."
                    echo ""
                    echo "  Commit message was:"
                    echo "$msg" | sed 's/^/    /'
                    exit 1
                fi
            fi
        done < <(git show --numstat --format='' "$sha")
    done
fi

# ---- 5. Conventional-commit format on subject line -----------------------
# Each commit subject must follow `<type>(<scope>): <description>` OR
# `<type>: <description>`. Codifies de-facto convention so the message
# format is machine-parseable. Covers common types in this repo:
#   feat, fix, docs, refactor, test, chore, perf, infra, build, ci, revert,
#   phase<N> (e.g., phase3, phase4), and case-by-case scope tags.
# Override: same NO-GATE: keyword as gate 4 also bypasses this gate.
COMMIT_TYPE_RE='^(feat|fix|docs|refactor|test|chore|perf|infra|build|ci|revert|phase[0-9]+)(\([a-zA-Z0-9_,/.\-]+\))?: .+'
if [ -n "$LOCAL" ] && [ -n "$REMOTE" ] && [ "$LOCAL" != "$REMOTE" ]; then
    BASE=$(git merge-base "$LOCAL" "$REMOTE" 2>/dev/null || echo "$REMOTE")
    for sha in $(git rev-list --no-merges --reverse "$BASE".."$LOCAL"); do
        msg=$(git log -1 --format=%B "$sha")
        if echo "$msg" | grep -qE '^NO-GATE:'; then
            continue
        fi
        subject=$(echo "$msg" | head -1)
        if ! echo "$subject" | grep -qE "$COMMIT_TYPE_RE"; then
            echo "[pre-push] BLOCK: commit $sha subject doesn't match conventional-commit format."
            echo "  Expected: <type>(<scope>): <description>  OR  <type>: <description>"
            echo "  Valid types: feat, fix, docs, refactor, test, chore, perf, infra, build, ci, revert, phase<N>"
            echo "  Got: $subject"
            echo "  Resolve: amend the commit message, OR add 'NO-GATE: <reason>' line for unconventional-but-justified subjects."
            exit 1
        fi
    done
fi

# ---- 6. Co-Authored-By trailer enforcement -------------------------------
# Owner-instituted pattern: AI-authored commits carry Co-Authored-By trailers
# for provenance. Threshold: any commit with >25 lines changed must have
# the trailer (covers all substantive agent-authored commits; trivial
# typo-fixes can skip).
COAUTH_THRESHOLD=25
if [ -n "$LOCAL" ] && [ -n "$REMOTE" ] && [ "$LOCAL" != "$REMOTE" ]; then
    BASE=$(git merge-base "$LOCAL" "$REMOTE" 2>/dev/null || echo "$REMOTE")
    for sha in $(git rev-list --no-merges --reverse "$BASE".."$LOCAL"); do
        msg=$(git log -1 --format=%B "$sha")
        if echo "$msg" | grep -qE '^NO-GATE:'; then
            continue
        fi
        # Compute total lines changed in this commit
        total=$(git show --numstat --format='' "$sha" | awk 'BEGIN{s=0} $1!="-" && $2!="-" {s += $1 + $2} END{print s+0}')
        if [ "$total" -gt "$COAUTH_THRESHOLD" ]; then
            if ! echo "$msg" | grep -qiE '^Co-Authored-By:'; then
                echo "[pre-push] BLOCK: commit $sha ($total lines changed) lacks Co-Authored-By trailer."
                echo "  Reason: provenance — substantive commits must declare authorship."
                echo "  Resolve: amend the commit to add (example):"
                echo "    Co-Authored-By: Claude Opus 4.7 (1M context) <noreply@anthropic.com>"
                echo "  OR use 'NO-GATE: <reason>' for owner-direct commits."
                exit 1
            fi
        fi
    done
fi

# ---- 7. Commit-message public-content audit ------------------------------
# Per Group P (owner-flagged 2026-05-07): commit messages are public history.
# Gate 1 scans file content but not commit messages; agent abbreviations,
# internal vocab, and AGENT-NAME patterns can slip through into git log via
# the message body. This gate scans messages of pushed commits with the same
# patterns gate 1 uses on file content.
if [ -n "$LOCAL" ] && [ -n "$REMOTE" ] && [ "$LOCAL" != "$REMOTE" ] && [ -f scripts/check-public-content.py ]; then
    PY7="$PY_BIN"
    if [ -n "$PY7" ]; then
        BASE=$(git merge-base "$LOCAL" "$REMOTE" 2>/dev/null || echo "$REMOTE")
        if ! "$PY7" scripts/check-public-content.py --commit-msgs "${BASE}..${LOCAL}"; then
            echo "[pre-push] BLOCK: commit-message audit failed (see above)"
            echo "  Resolve: amend the flagged commit message(s) before pushing."
            echo "    git rebase -i ${BASE}      # interactive rebase to amend specific commits"
            echo "  OR for legitimate uses, add to scripts/check-public-content.allowlist."
            exit 1
        fi
    fi
fi

# ---- 8. New package.yml MUST declare verify_paths -----------------------
# Stop-the-bleeding gate for the linux-firmware-class regression: any new
# packages/<tier>/<name>/package.yml file in the to-be-pushed commits must
# declare a `verify_paths:` field (or `pending_acquisition:` for deliberately-
# deferred packages). This forces every NEW package to self-document the
# files it produces, so the pre-squashfs audit has teeth from day one.
# Existing packages without verify_paths (the 294-package backlog) are
# tracked separately and not gated here — modifications to those won't
# fail this gate. Override: NO-GATE keyword in commit body.
if [ -n "$LOCAL" ] && [ -n "$REMOTE" ] && [ "$LOCAL" != "$REMOTE" ]; then
    BASE=$(git merge-base "$LOCAL" "$REMOTE" 2>/dev/null || echo "$REMOTE")
    # Check each commit in the push range; collect NO-GATE-exempted shas
    NEW_YMLS=()
    for sha in $(git rev-list --no-merges --reverse "$BASE".."$LOCAL"); do
        msg=$(git log -1 --format=%B "$sha")
        if echo "$msg" | grep -qE '^NO-GATE:'; then
            continue
        fi
        # Find files ADDED in this commit (status A) matching packages/*/*/package.yml
        while IFS=$'\t' read -r status file; do
            if [ "$status" = "A" ] && [[ "$file" =~ ^packages/[^/]+/[^/]+/package\.yml$ ]]; then
                NEW_YMLS+=("$sha:$file")
            fi
        done < <(git show --name-status --format='' "$sha")
    done

    BAD_PKGS=()
    for entry in "${NEW_YMLS[@]:-}"; do
        [ -z "$entry" ] && continue
        sha="${entry%%:*}"
        file="${entry#*:}"
        # Read the file at the version that was committed
        content=$(git show "$sha:$file" 2>/dev/null)
        if ! echo "$content" | grep -qE '^(verify_paths|pending_acquisition)\s*:'; then
            BAD_PKGS+=("$sha:$file")
        fi
    done

    if [ "${#BAD_PKGS[@]}" -gt 0 ]; then
        echo "[pre-push] BLOCK: new package.yml file(s) without verify_paths:"
        for entry in "${BAD_PKGS[@]}"; do
            sha="${entry%%:*}"
            file="${entry#*:}"
            echo "    $file  (in commit $sha)"
        done
        echo ""
        echo "  Reason: every new package must self-document load-bearing files"
        echo "  (verify_paths:) so the pre-squashfs audit has teeth. This catches"
        echo "  the linux-firmware-class regression (package recipe present,"
        echo "  package installs silently nothing) before it reaches a built ISO."
        echo ""
        echo "  Resolve options:"
        echo "    (a) Add a verify_paths: field declaring 2-3 load-bearing files"
        echo "        the package installs (see existing package.yml examples)."
        echo "    (b) For deliberately-deferred packages: use pending_acquisition:"
        echo "        with a reason (see core/shim-signed/package.yml)."
        echo "    (c) NO-GATE: <reason> in commit body for legitimate exemptions."
        exit 1
    fi
fi

# ---- 9. v1.1 deferred-followup consistency -------------------------------
# Per the O-030-followup mechanism (operator greenlit 2026-05-19): every
# commit that defers scope to v1.1 must register the deferral in
# docs/v1.1-deferred-followups.md, so the ledger of v1.0/v1.1 scope splits
# stays auditable and the work cannot be silently lost. The gate scans
# commit bodies in the push range for future-version-deferral framing; each
# flagged commit must either reference an existing F-NNN entry by ID OR
# modify docs/v1.1-deferred-followups.md in the same commit. Override:
# NO-GATE keyword in commit body (use sparingly; flag operator).
if [ -n "$LOCAL" ] && [ -n "$REMOTE" ] && [ "$LOCAL" != "$REMOTE" ]; then
    BASE=$(git merge-base "$LOCAL" "$REMOTE" 2>/dev/null || echo "$REMOTE")
    V11_VIOLATIONS=()
    for sha in $(git rev-list --no-merges --reverse "$BASE".."$LOCAL"); do
        msg=$(git log -1 --format=%B "$sha")
        if echo "$msg" | grep -qE '^NO-GATE:'; then
            continue
        fi
        # Patterns that flag a v1.1 / post-v1.0 deferral
        if echo "$msg" | grep -qiE 'deferred to v1\.1|post-v1\.0|in v1\.1|v1\.1 follow-?up|defer.{0,40}v1\.1'; then
            has_fnnn=0
            has_doc_mod=0
            if echo "$msg" | grep -qE 'F-[0-9]{3,}'; then
                has_fnnn=1
            fi
            if git show --name-only --format='' "$sha" | grep -qx 'docs/v1.1-deferred-followups.md'; then
                has_doc_mod=1
            fi
            if [ "$has_fnnn" -eq 0 ] && [ "$has_doc_mod" -eq 0 ]; then
                V11_VIOLATIONS+=("$sha")
            fi
        fi
    done
    if [ "${#V11_VIOLATIONS[@]}" -gt 0 ]; then
        echo "[pre-push] BLOCK: v1.1 deferral(s) without ledger entry:"
        for sha in "${V11_VIOLATIONS[@]}"; do
            subj=$(git log -1 --format=%s "$sha")
            echo "    $sha  $subj"
        done
        echo ""
        echo "  Reason: every commit that defers scope to v1.1 must register"
        echo "  the deferral in docs/v1.1-deferred-followups.md so the work"
        echo "  is auditable and cannot be silently lost. See the doc header"
        echo "  for the entry shape."
        echo ""
        echo "  Resolve options:"
        echo "    (a) Add an F-NNN entry to docs/v1.1-deferred-followups.md"
        echo "        in this commit set, then reference its ID in the body."
        echo "    (b) Reference an existing F-NNN entry by ID if one already"
        echo "        covers this deferral."
        echo "    (c) NO-GATE: <reason> in commit body for legitimate edge"
        echo "        cases (operator-direct authorization advised)."
        exit 1
    fi
fi

echo "[pre-push] all gates PASS"
exit 0

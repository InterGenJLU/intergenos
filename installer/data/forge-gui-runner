#!/bin/sh
# /usr/bin/forge-gui-runner — Live-ISO Forge GUI runner (runs as root after pkexec).
#
# Step 2 of the two-stage pkexec flow. Reads the env-restoration file the
# intergenos-side launcher wrote to /run/user/$PKEXEC_UID/forge-gui.env,
# restores the relevant display/bus environment variables, and execs
# /usr/bin/forge with the fixed GUI install arguments.
#
# This script is the actual polkit-action target (see
# /usr/share/polkit-1/actions/org.intergenos.forge.policy
# exec.path annotation); the rule at
# /usr/share/polkit-1/rules.d/49-intergenos-forge.rules grants
# passwordless YES to subject.user == "intergenos" for the
# org.intergenos.forge.run-installer action. The arguments passed to
# forge are hardcoded here rather than accepted from argv: the
# passwordless polkit grant covers only this exact root invocation, so
# intergenos cannot inject alternate arguments (e.g. --mode tui in a way
# that bypasses GUI consent) by tampering with the .desktop file or
# autostart entry.

set -eu

# Argv strict equality: forge-gui-runner takes NO arguments. The args to
# /usr/bin/forge are hardcoded below per the polkit-action security
# contract (passwordless grant only covers this exact root invocation;
# intergenos cannot inject alternate arguments). Reject any positional
# argv at the runner layer as defense-in-depth — even though argv is
# unused, refusing extras prevents future drift where a maintainer
# accidentally starts reading $1 + a malicious caller has already been
# passing crafted args.
if [ "$#" -ne 0 ]; then
    printf 'forge-gui-runner: takes no arguments; got %d. Refusing.\n' "$#" >&2
    exit 2
fi

# PKEXEC_UID is set by pkexec to the calling user's uid. Refuse to run
# outside a pkexec context — a direct root invocation would either crash
# on the missing env file or restore env from a wrong /run/user/<uid>.
PKEXEC_UID="${PKEXEC_UID:-}"
if [ -z "${PKEXEC_UID}" ]; then
    printf 'forge-gui-runner: PKEXEC_UID unset; refusing to run outside pkexec.\n' >&2
    exit 1
fi

ENV_FILE="/run/user/${PKEXEC_UID}/forge-gui.env"
if [ ! -r "${ENV_FILE}" ]; then
    printf 'forge-gui-runner: env file %s missing or unreadable.\n' "${ENV_FILE}" >&2
    exit 1
fi

# Diagnostic logging: runner appends to its own log too so we know whether
# pkexec actually launched us and what env we received.
exec >>/tmp/forge-gui-runner.log 2>&1
echo "=== forge-gui-runner invoked $(date -Iseconds) uid=$(id -u) PKEXEC_UID=${PKEXEC_UID} ==="

# Parse and export. Allow-list the env vars we propagate. Skip empty values
# (IGOSC's 2026-05-16 H1: empty GDK_BACKEND breaks GTK4 init paths). The
# launcher now omits empty entries, so this is belt-and-suspenders.
while IFS='=' read -r key value; do
    [ -z "${key}" ] && continue
    [ -z "${value}" ] && continue
    case "${key}" in
        DISPLAY|WAYLAND_DISPLAY|XAUTHORITY|XDG_RUNTIME_DIR|XDG_SESSION_TYPE|DBUS_SESSION_BUS_ADDRESS|GDK_BACKEND|GTK_USE_PORTAL)
            export "${key}=${value}"
            echo "exported ${key}=${value}"
            ;;
    esac
done < "${ENV_FILE}"

echo "execing /usr/bin/forge --mode gui ..."
exec /usr/bin/forge --mode gui \
    --archives /var/lib/igos/archives \
    --packages /usr/share/intergenos/installer-hooks

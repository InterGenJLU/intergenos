#!/bin/sh
# /usr/bin/forge-gui-launch — Live-ISO Forge GUI launcher (runs as liveuser).
#
# Step 1 of the two-stage pkexec flow that brings up Forge's GTK4/libadwaita
# GUI as root while preserving access to the calling liveuser session's
# display server, X authority, runtime directory, and D-Bus session bus.
#
# pkexec scrubs the caller's environment to a tiny whitelist on invocation
# (LANG/LC_*, PATH, SHELL, USER, USERNAME, LOGNAME, HOME — and, when the
# action's allow_gui annotation is set, DISPLAY and XAUTHORITY). It does
# NOT preserve WAYLAND_DISPLAY, XDG_RUNTIME_DIR, or
# DBUS_SESSION_BUS_ADDRESS, so a root child process cannot reach the user
# session's wayland socket or D-Bus session bus by default. Forge's
# top-level GTK4 window can render via implicit fallbacks, but the
# moment it makes an xdg-desktop-portal call (file chooser, partition
# picker, account assistant), D-Bus auto-activation spawns a fresh
# xdg-desktop-portal-gtk process in root's session-less context where
# DISPLAY/WAYLAND_DISPLAY are unset. Portal-gtk fails with
# "cannot open display:" and the calling portal client times out at 120s.
#
# This script captures the relevant env vars to a file in the caller's
# /run/user/$UID directory (mode 0700, only owner-uid and root can read),
# then execs the root-side runner via pkexec. The runner reads the file
# (root reads regardless of mode), restores the env, and execs forge.

# Diagnostic logging: every invocation appends to /tmp/forge-gui-launch.log so
# post-mortem can confirm whether autostart fired and where it died.
exec >>/tmp/forge-gui-launch.log 2>&1
echo "=== forge-gui-launch invoked $(date -Iseconds) uid=$(id -u) ==="
trap 'echo "EXIT line=$LINENO rc=$?"' EXIT

set -eu

UID_NUM="$(id -u)"
RUNTIME_DIR="${XDG_RUNTIME_DIR:-/run/user/${UID_NUM}}"
ENV_FILE="${RUNTIME_DIR}/forge-gui.env"

# Defensive: ensure RUNTIME_DIR exists before write. logind creates it at
# session start but XDG autostart can race with the dir-create step.
mkdir -p "${RUNTIME_DIR}"

# Write env-restoration file. Skip empty values entirely so the runner never
# exports empty-string vars (IGOSC's 2026-05-16 H1: GDK_BACKEND='' is NOT the
# same as unset to GTK4 init; some paths interpret empty as "no match" and
# silently fail). Only key=value lines for vars that are actually set.
umask 0177
{
    [ -n "${DISPLAY:-}" ]                  && printf 'DISPLAY=%s\n'                  "$DISPLAY"
    [ -n "${WAYLAND_DISPLAY:-}" ]          && printf 'WAYLAND_DISPLAY=%s\n'          "$WAYLAND_DISPLAY"
    [ -n "${XAUTHORITY:-}" ]               && printf 'XAUTHORITY=%s\n'               "$XAUTHORITY"
                                              printf 'XDG_RUNTIME_DIR=%s\n'          "$RUNTIME_DIR"
    [ -n "${XDG_SESSION_TYPE:-}" ]         && printf 'XDG_SESSION_TYPE=%s\n'         "$XDG_SESSION_TYPE"
                                              printf 'DBUS_SESSION_BUS_ADDRESS=%s\n' "${DBUS_SESSION_BUS_ADDRESS:-unix:path=${RUNTIME_DIR}/bus}"
    [ -n "${GDK_BACKEND:-}" ]              && printf 'GDK_BACKEND=%s\n'              "$GDK_BACKEND"
    # GTK_USE_PORTAL=1 intentionally always set (file-chooser portal handoff).
                                              printf 'GTK_USE_PORTAL=1\n'
} > "${ENV_FILE}"

echo "env file written: ${ENV_FILE} ($(wc -l <"${ENV_FILE}") lines)"
cat "${ENV_FILE}" | sed 's/^/  /'

echo "calling pkexec /usr/bin/forge-gui-runner"
exec pkexec /usr/bin/forge-gui-runner

# Filesystem artifacts
lost+found/

# Build artifacts (generated, not source)
build/work/
build/system/
build/packages/
build/logs/
build/checkpoints/
build/sources/
build/vendor-artifacts/
build/archive/
build/*.db

# Operational scripts (per-build/resume kickoff wrappers; generated, not source)
build/build*-kickoff.sh
build/build*-rebuild-*.sh
build/option-*.sh

# Timestamped scanner output at build/ root (regenerate per scan).
# Pattern matches *-YYYYMMDDTHHMMSSZ.{tsv,json};
# preserves build/audits/ (tracked per-package audit JSONs)
# and build/rule5-sweep-results.tsv (tracked classifier output).
build/*-[0-9]*Z.tsv
build/*-[0-9]*Z.json

# Transient scanner working directories
build/scan-cache/
build/sources-pax-regen/
*.iso
*.img
*.img.gz
*.qcow2

# KVM virtual machines
vm/*.qcow2
vm/*.iso

# LFS/BLFS reference books and derived databases (local only)
# BLFS 13.0 © 1999-2026 The BLFS Development Team (CC BY-NC-SA 2.0)
# LFS 13.0 © 1999-2026 Gerard Beekmans et al. (CC BY-NC-SA 2.0)
docs/lfs-13.0/

# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/

# IDE / tools
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Research working directory (local, may contain sensitive notes)
# Published research is committed under docs/research/
research/
!docs/research/

# Logs
*.log

# Temporary
tmp/

# AI assistant configuration and editor plugin runtime
# Host-local developer tooling, not part of distro source
.claude/
.deepseek/
.kilo/
.kilocode/
kilo.json.fragment

# External icon-pack binary archives — reference material, not research
docs/research/**/*.tar.xz
docs/research/**/*.tar.gz

intergen/tests/results/

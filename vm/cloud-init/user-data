#cloud-config
autoinstall:
  version: 1
  locale: en_US.UTF-8
  keyboard:
    layout: us
  identity:
    hostname: igos-build
    username: <username>
    # Generate with: python3 -c "import crypt; print(crypt.crypt('YOUR_PASSWORD', crypt.mksalt(crypt.METHOD_SHA512)))"
    password: "REPLACE_WITH_PASSWORD_HASH"
  ssh:
    install-server: true
    allow-pw: true
    authorized-keys:
      # Paste your SSH public key here (e.g., from ~/.ssh/id_ed25519.pub)
      - REPLACE_WITH_SSH_PUBLIC_KEY
  storage:
    layout:
      name: lvm
      sizing-policy: all
  packages:
    - openssh-server
    - qemu-guest-agent
    - build-essential
    - bison
    - gawk
    - texinfo
    - python3
    - python3-pip
  late-commands:
    - echo "intergenos /mnt/intergenos virtiofs defaults,nofail 0 0" >> /target/etc/fstab
    - mkdir -p /target/mnt/intergenos
    # Ensure bash is /bin/sh (LFS requirement)
    - ln -sf bash /target/bin/sh
    # Give build user sudo without password for build automation
    - echo "<username> ALL=(ALL) NOPASSWD:ALL" > /target/etc/sudoers.d/<username>
    - chmod 440 /target/etc/sudoers.d/<username>
  user-data:
    disable_root: true
    timezone: America/Chicago

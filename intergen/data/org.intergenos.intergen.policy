<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE policyconfig PUBLIC
 "-//freedesktop//DTD PolicyKit Policy Configuration 1.0//EN"
 "http://www.freedesktop.org/standards/PolicyKit/1.0/policyconfig.dtd">
<!--
  InterGen pkexec policy — T0-4-E integration gate.

  Wires the D-007 Option A "every privileged action via PolicyKit"
  requirement for the runtime AI-tool dispatch path. Composes with the
  D-008 provenance gate (intergen/provenance.py): the provenance gate
  authorizes INTENT before this policy authorizes AUTHENTICATION. Both
  fire for privileged operations per the RFC v0.1 §6 line 161 "the two
  don't replace each other" invariant.

  Coverage: one action covers the entire privileged-tool tier (per RFC §6
  taxonomy: manage_services on system services + manage_packages +
  run_command with sudo + write_file to /etc/). The privileged-tool
  list and per-tool argument validation live in the runner's Python
  dispatcher entry point (intergen.privileged_dispatch) — pkexec is
  the AUTHENTICATION boundary, intergen.privileged_dispatch is the
  AUTHORIZATION + ARGUMENT-VALIDATION boundary, and IGOSC's
  intergen/tool_registry.py + intergen/provenance.py are the INTENT
  boundary upstream.

  auth_admin_keep matches the forge installer pattern: the user
  authenticates once + the cached credentials are valid for the
  session. For a personal-machine AI assistant making multiple
  tool calls per conversation, re-prompting per-call would be
  user-hostile without adding security (the same user authentication
  covers the same conversation's tool calls; the provenance gate is
  the per-call intent check, not the per-call authentication).
-->
<policyconfig>
  <vendor>InterGenOS</vendor>
  <vendor_url>https://github.com/InterGenJLU/intergenos</vendor_url>
  <icon_name>system-software-install</icon_name>

  <action id="org.intergenos.intergen.privileged-tool">
    <description>Run a privileged system action via InterGen AI</description>
    <description xml:lang="en_US">Run a privileged system action via InterGen AI</description>
    <message>Authentication is required to let InterGen perform a privileged system action on your behalf</message>
    <message xml:lang="en_US">Authentication is required to let InterGen perform a privileged system action on your behalf</message>
    <defaults>
      <allow_any>auth_admin_keep</allow_any>
      <allow_inactive>auth_admin_keep</allow_inactive>
      <allow_active>auth_admin_keep</allow_active>
    </defaults>
    <annotate key="org.freedesktop.policykit.exec.path">/usr/bin/intergen-privileged-runner</annotate>
    <annotate key="org.freedesktop.policykit.exec.allow_gui">true</annotate>
  </action>
</policyconfig>

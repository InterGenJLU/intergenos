# InterGenOS Kernel Config Fragment: Network Drivers
# Covers ~95% of wired and wireless NICs
# All as modules — not needed for boot

# Network stack
CONFIG_NET=y
CONFIG_INET=y
CONFIG_IPV6=y
CONFIG_NETFILTER=y
CONFIG_NF_CONNTRACK=m
CONFIG_NETFILTER_XTABLES=m
CONFIG_IP_NF_IPTABLES=m
CONFIG_IP_NF_FILTER=m
CONFIG_IP_NF_NAT=m
CONFIG_NF_NAT=m

# --- Wired Ethernet ---

# Intel (covers most desktop/laptop/server NICs)
CONFIG_E1000=m
CONFIG_E1000E=m
CONFIG_IGB=m
CONFIG_IGC=m
CONFIG_IXGBE=m

# Realtek (extremely common on consumer boards)
CONFIG_R8169=m

# Broadcom
CONFIG_BNX2X=m
CONFIG_BNXT_EN=m
CONFIG_TIGON3=m

# Aquantia/Marvell (2.5G/5G/10G)
CONFIG_ATLANTIC=m

# --- Wireless ---

# Intel WiFi (most laptops)
CONFIG_IWLWIFI=m
CONFIG_IWLMVM=m
CONFIG_IWLDVM=m

# Qualcomm/Atheros
CONFIG_ATH9K=m
CONFIG_ATH10K=m
CONFIG_ATH10K_PCI=m
CONFIG_ATH11K=m
CONFIG_ATH11K_PCI=m
CONFIG_ATH12K=m

# Realtek WiFi
CONFIG_RTW88=m
CONFIG_RTW88_PCI=m
CONFIG_RTW89=m
CONFIG_RTW89_PCI=m

# Broadcom WiFi
CONFIG_BRCMFMAC=m
CONFIG_BRCMSMAC=m

# MediaTek WiFi
CONFIG_MT76=m
CONFIG_MT7921E=m

# WiFi framework
CONFIG_CFG80211=m
CONFIG_MAC80211=m

# InterGenOS Kernel Config Fragment: KVM Guest Support
# Virtio drivers for running InterGenOS inside KVM/QEMU
# Essential for our build VM and testing

CONFIG_PARAVIRT=y
CONFIG_PARAVIRT_GUEST=y
CONFIG_KVM_GUEST=y

# Virtio core — must be built-in (=y) since we boot without initramfs
CONFIG_VIRTIO=y
CONFIG_VIRTIO_PCI=y
CONFIG_VIRTIO_PCI_MODERN=y
CONFIG_VIRTIO_PCI_LEGACY=y
CONFIG_VIRTIO_MMIO=y

# Virtio devices — block and net built-in (needed before root mount)
CONFIG_VIRTIO_BLK=y
CONFIG_VIRTIO_NET=y
CONFIG_SCSI_VIRTIO=y
CONFIG_VIRTIO_CONSOLE=y
CONFIG_VIRTIO_BALLOON=y
CONFIG_VIRTIO_INPUT=y

# Virtiofs (host-guest file sharing)
CONFIG_FUSE_FS=y
CONFIG_VIRTIO_FS=y

# VirtIO RNG
CONFIG_HW_RANDOM_VIRTIO=y

# VirtIO GPU (for graphical console)
CONFIG_DRM_VIRTIO_GPU=y

# InterGenOS Kernel Config Fragment: Bluetooth
# Common BT controllers (Intel, Broadcom, Realtek, Qualcomm)

CONFIG_BT=m
CONFIG_BT_RFCOMM=m
CONFIG_BT_HIDP=m
CONFIG_BT_BNEP=m
CONFIG_BT_LEDS=y

# USB Bluetooth adapters
CONFIG_BT_HCIBTUSB=m

# Intel Bluetooth
CONFIG_BT_INTEL=m

# Broadcom Bluetooth
CONFIG_BT_BCM=m
CONFIG_BT_HCIUART=m

# Realtek Bluetooth
CONFIG_BT_RTL=m

# Qualcomm/Atheros Bluetooth
CONFIG_BT_ATH3K=m
CONFIG_BT_QCA=m

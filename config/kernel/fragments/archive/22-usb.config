# InterGenOS Kernel Config Fragment: USB
# Host controller drivers and common device classes

# USB core
CONFIG_USB_SUPPORT=y
CONFIG_USB=y
CONFIG_USB_ANNOUNCE_NEW_DEVICES=y

# Host controllers
CONFIG_USB_XHCI_HCD=y
CONFIG_USB_EHCI_HCD=y
CONFIG_USB_OHCI_HCD=m

# USB device classes
CONFIG_USB_HID=m
CONFIG_USB_PRINTER=m
CONFIG_USB_STORAGE=m
CONFIG_USB_UAS=m
CONFIG_USB_SERIAL=m
CONFIG_USB_ACM=m

# Thunderbolt/USB4
CONFIG_THUNDERBOLT=m

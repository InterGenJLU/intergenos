# InterGenOS Kernel Config Fragment: KVM Host (Virtualization)
# Enable InterGenOS as a KVM/QEMU hypervisor host
#
# 40-kvm-guest.config covers running INSIDE a VM
# This fragment covers running VMs ON InterGenOS

# KVM core
CONFIG_VIRTUALIZATION=y
CONFIG_KVM=m
CONFIG_KVM_AMD=m
CONFIG_KVM_INTEL=m

# VFIO (GPU/device passthrough)
CONFIG_VFIO=m
CONFIG_VFIO_PCI=m
CONFIG_VFIO_IOMMU_TYPE1=m
CONFIG_VFIO_VIRQFD=m

# IOMMU (required for device passthrough)
CONFIG_IOMMU_SUPPORT=y
CONFIG_AMD_IOMMU=y
CONFIG_INTEL_IOMMU=y
CONFIG_IOMMU_API=y

# TUN/TAP (VM networking)
CONFIG_TUN=m
CONFIG_MACVLAN=m
CONFIG_MACVTAP=m

# Bridge (VM networking)
CONFIG_BRIDGE=m

# Virtio host support (for hosting VMs with virtio devices)
CONFIG_VHOST=m
CONFIG_VHOST_NET=m
CONFIG_VHOST_VSOCK=m

# Huge pages (KVM performance)
CONFIG_HUGETLBFS=y
CONFIG_HUGETLB_PAGE=y
CONFIG_TRANSPARENT_HUGEPAGE=y

# eventfd (KVM inter-process signaling)
CONFIG_EVENTFD=y

# Nested virtualization support
CONFIG_KVM_AMD_SEV=y

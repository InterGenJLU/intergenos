# InterGenOS Kernel Config Fragment: Security
# Baseline hardening — no MAC framework (AppArmor/SELinux) by default

# Stack protection
CONFIG_STACKPROTECTOR=y
CONFIG_STACKPROTECTOR_STRONG=y

# Address Space Layout Randomization
CONFIG_RANDOMIZE_BASE=y
CONFIG_RANDOMIZE_MEMORY=y

# Syscall filtering (used by systemd, containers, browsers)
CONFIG_SECCOMP=y
CONFIG_SECCOMP_FILTER=y

# Hardened usercopy
CONFIG_HARDENED_USERCOPY=y

# Restrict kernel address exposure
CONFIG_SECURITY_DMESG_RESTRICT=y

# Module signing (optional — enable if distributing)
# CONFIG_MODULE_SIG=y
# CONFIG_MODULE_SIG_FORCE=y

# Lockdown (optional — restricts kernel modification at runtime)
CONFIG_SECURITY_LOCKDOWN_LSM=y
CONFIG_SECURITY_LOCKDOWN_LSM_EARLY=y
CONFIG_LOCK_DOWN_KERNEL_FORCE_NONE=y

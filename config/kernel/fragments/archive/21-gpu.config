# InterGenOS Kernel Config Fragment: GPU/Display
# Kernel Mode Setting drivers for desktop display
# All as modules — DRM_SIMPLEDRM provides fallback

# DRM core
CONFIG_DRM=m
CONFIG_DRM_KMS_HELPER=m
CONFIG_DRM_FBDEV_EMULATION=y

# Intel integrated graphics
CONFIG_DRM_I915=m

# AMD (Radeon + AMDGPU)
CONFIG_DRM_AMDGPU=m
CONFIG_DRM_AMDGPU_CIK=y
CONFIG_DRM_AMDGPU_SI=y
CONFIG_DRM_RADEON=m

# NVIDIA (open-source nouveau driver)
CONFIG_DRM_NOUVEAU=m

# Simple DRM — UEFI/firmware framebuffer fallback
# Built-in so there's always a display
CONFIG_DRM_SIMPLEDRM=y

# Backlight support (laptops)
CONFIG_BACKLIGHT_CLASS_DEVICE=y
CONFIG_BACKLIGHT_GENERIC=m

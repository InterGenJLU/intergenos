# InterGenOS Kernel Config Fragment: Filesystems
# Root filesystem driver must be built-in (=y)
# Others as modules for flexibility

# Primary filesystem — must be built-in for root mount
CONFIG_EXT4_FS=y
CONFIG_EXT4_FS_POSIX_ACL=y
CONFIG_EXT4_FS_SECURITY=y

# Common filesystems (modules)
CONFIG_BTRFS_FS=m
CONFIG_BTRFS_FS_POSIX_ACL=y
CONFIG_XFS_FS=m
CONFIG_XFS_POSIX_ACL=y
CONFIG_F2FS_FS=m
CONFIG_NTFS3_FS=m

# Required for UEFI ESP (FAT32)
CONFIG_VFAT_FS=y
CONFIG_FAT_FS=y
CONFIG_NLS_CODEPAGE_437=y
CONFIG_NLS_ISO8859_1=y
CONFIG_NLS_UTF8=y

# Pseudo filesystems (required)
CONFIG_PROC_FS=y
CONFIG_SYSFS=y
CONFIG_TMPFS=y
CONFIG_TMPFS_POSIX_ACL=y
CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=y

# ISO/Squashfs (for live media and package management)
CONFIG_ISO9660_FS=m
CONFIG_SQUASHFS=m
CONFIG_SQUASHFS_ZLIB=y
CONFIG_SQUASHFS_LZ4=y
CONFIG_SQUASHFS_ZSTD=y
CONFIG_SQUASHFS_XZ=y

# FUSE (for user-space filesystems)
CONFIG_FUSE_FS=m

# Network filesystems
CONFIG_NFS_FS=m
CONFIG_CIFS=m

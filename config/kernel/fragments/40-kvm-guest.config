# InterGenOS Kernel Config Fragment: KVM Guest Support
# Virtio drivers for running InterGenOS inside KVM/QEMU
# Essential for our build VM and testing

CONFIG_PARAVIRT=y
CONFIG_PARAVIRT_GUEST=y
CONFIG_KVM_GUEST=y

# Virtio core
CONFIG_VIRTIO=m
CONFIG_VIRTIO_PCI=m
CONFIG_VIRTIO_MMIO=m

# Virtio devices
CONFIG_VIRTIO_BLK=m
CONFIG_VIRTIO_NET=m
CONFIG_SCSI_VIRTIO=m
CONFIG_VIRTIO_CONSOLE=m
CONFIG_VIRTIO_BALLOON=m
CONFIG_VIRTIO_INPUT=m

# Virtiofs (host-guest file sharing)
CONFIG_FUSE_FS=m
CONFIG_VIRTIO_FS=m

# VirtIO RNG
CONFIG_HW_RANDOM_VIRTIO=m

# VirtIO GPU (for graphical console)
CONFIG_DRM_VIRTIO_GPU=m

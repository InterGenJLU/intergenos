# InterGenOS Kernel Config Fragment: systemd Requirements
# These are non-negotiable for a systemd-based system

# Device management
CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=y

# Control groups (systemd foundation)
CONFIG_CGROUPS=y
CONFIG_CGROUP_CPUACCT=y
CONFIG_CGROUP_DEVICE=y
CONFIG_CGROUP_FREEZER=y
CONFIG_CGROUP_MEMORY=y
CONFIG_CGROUP_PIDS=y
CONFIG_CGROUP_SCHED=y
CONFIG_MEMCG=y

# Namespaces (containers, sandboxing)
CONFIG_NAMESPACES=y
CONFIG_NET_NS=y
CONFIG_PID_NS=y
CONFIG_IPC_NS=y
CONFIG_UTS_NS=y
CONFIG_USER_NS=y

# DMI (hardware detection)
CONFIG_DMIID=y

# Inotify (file watching)
CONFIG_INOTIFY_USER=y

# Signalfd, timerfd, eventfd
CONFIG_SIGNALFD=y
CONFIG_TIMERFD=y
CONFIG_EVENTFD=y
CONFIG_EPOLL=y

# /dev/pts
CONFIG_UNIX98_PTYS=y
CONFIG_DEVPTS_MULTIPLE_INSTANCES=y

# Pressure Stall Information (systemd-oomd)
CONFIG_PSI=y
CONFIG_PSI_DEFAULT_DISABLED=n

# Audit (systemd journal)
CONFIG_AUDIT=y

# BPF (modern systemd features)
CONFIG_BPF=y
CONFIG_BPF_SYSCALL=y
CONFIG_CGROUP_BPF=y

# Autofs (systemd automount)
CONFIG_AUTOFS_FS=y

# InterGenOS Kernel Config Fragment: Storage
# Covers ~95% of storage hardware via standard protocols
#
# AHCI (SATA), NVMe, SCSI framework, USB storage
# These are built-in (=y) because they're needed before root mount

# SCSI subsystem (framework for SATA/USB/etc)
CONFIG_SCSI=y
CONFIG_BLK_DEV_SD=y
CONFIG_CHR_DEV_SG=y
CONFIG_SCSI_SPI_ATTRS=y

# SATA/AHCI — covers virtually all SATA controllers
CONFIG_ATA=y
CONFIG_SATA_AHCI=y
CONFIG_ATA_PIIX=y
CONFIG_SATA_AHCI_PLATFORM=y

# NVMe — all modern SSDs
CONFIG_BLK_DEV_NVME=y
CONFIG_NVME_CORE=y

# USB Mass Storage
CONFIG_USB_STORAGE=m

# MD/RAID (software RAID)
CONFIG_MD=y
CONFIG_BLK_DEV_MD=m
CONFIG_MD_RAID0=m
CONFIG_MD_RAID1=m
CONFIG_MD_RAID10=m
CONFIG_MD_RAID456=m

# Device Mapper (LVM, encryption)
CONFIG_BLK_DEV_DM=y
CONFIG_DM_CRYPT=m
CONFIG_DM_MIRROR=m
CONFIG_DM_SNAPSHOT=m
CONFIG_DM_THIN_PROVISIONING=m

# Loop devices
CONFIG_BLK_DEV_LOOP=y

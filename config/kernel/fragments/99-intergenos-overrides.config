# InterGenOS Kernel Config Overrides
# Options not covered by the universal baseline (5-distro convergence)
# These are InterGenOS-specific choices or niche hardware drivers

# --- Architecture ---
CONFIG_X86_64=y
CONFIG_NR_CPUS=512
CONFIG_PREEMPT=y
CONFIG_HZ=1000
CONFIG_NO_HZ_IDLE=y
CONFIG_X86_ACPI_CPUFREQ=y

# --- Storage ---
# RULE: Everything between CPU and root filesystem MUST be built-in.
# No initramfs should ever be required to mount root.
# This covers: storage controllers, SCSI disk, filesystems, partition tables.
CONFIG_SATA_AHCI=y
CONFIG_SATA_AHCI_PLATFORM=y
CONFIG_ATA_PIIX=y
CONFIG_NVME_CORE=y
CONFIG_BLK_DEV_NVME=y
CONFIG_VIRTIO_BLK=y
CONFIG_SCSI_VIRTIO=y
CONFIG_BLK_DEV_SD=y
CONFIG_EXT4_FS=y
CONFIG_USB_STORAGE=y

# --- UEFI ---
CONFIG_EFI_ESRT=y
CONFIG_EFI_CAPSULE_LOADER=m
CONFIG_FB_EFI=y

# --- systemd requirements ---
CONFIG_CGROUP_MEMORY=y
CONFIG_PSI_DEFAULT_DISABLED=n
CONFIG_BPF=y

# --- Network drivers (additional coverage) ---
CONFIG_BNXT_EN=m
CONFIG_ATLANTIC=m
CONFIG_RTW88_PCI=m
CONFIG_RTW89_PCI=m
CONFIG_MT76=m

# --- GPU ---
CONFIG_DRM_KMS_HELPER=m
CONFIG_DRM_AMDGPU=m
CONFIG_DRM_RADEON=m
CONFIG_BACKLIGHT_GENERIC=m

# --- USB ---
# USB_STORAGE already set =y in Storage section above
CONFIG_USB_UAS=y
CONFIG_THUNDERBOLT=m

# --- Input ---
CONFIG_MOUSE_PS2=y

# --- Sound ---
CONFIG_SND_TIMER=m
CONFIG_SND_PCM=m
CONFIG_SND_MIXER_OSS=m
CONFIG_SND_PCM_OSS=m

# --- Bluetooth drivers ---
CONFIG_BT_INTEL=m
CONFIG_BT_BCM=m
CONFIG_BT_HCIUART=m
CONFIG_BT_RTL=m
CONFIG_BT_QCA=m

# --- Firewall / Netfilter ---
# iptables built-in for basic firewall without loading modules
CONFIG_NF_CONNTRACK=y
CONFIG_IP_NF_IPTABLES=y
CONFIG_IP_TABLES=y
CONFIG_IP_NF_FILTER=y
CONFIG_IP_NF_TARGET_REJECT=y
CONFIG_IP6_NF_IPTABLES=y
CONFIG_IP6_NF_FILTER=y
CONFIG_NF_TABLES=y

# --- Security ---
CONFIG_SECCOMP_FILTER=y
CONFIG_SECURITY_LOCKDOWN_LSM_EARLY=y

# --- KVM guest (VM support) ---
CONFIG_PARAVIRT_GUEST=y
CONFIG_VIRTIO_PCI_MODERN=y

# --- KVM host (hypervisor) ---
CONFIG_VFIO_IOMMU_TYPE1=m
CONFIG_IOMMU_API=y
CONFIG_VHOST=m
CONFIG_KVM_AMD_SEV=y

# --- IoT/Smart Home ---
CONFIG_I2C_GPIO=m
CONFIG_SPI_SPIDEV=m
CONFIG_SPI_GPIO=m
CONFIG_GPIO_CHARDEV=y
CONFIG_W1_GPIO=m
CONFIG_W1_THERM=m
CONFIG_NFC_PN533=m

# --- HP Laptop specific (from Arch config / kernel briefing) ---
# Intel SOF audio (Ice Lake)
CONFIG_SND_SOC_CORE=m
CONFIG_SND_SOC_ACPI=m
CONFIG_SND_SOC_ACPI_INTEL_MATCH=m
CONFIG_SND_HDA_EXT_CORE=m
CONFIG_SND_INTEL_DSPCFG=m
CONFIG_SND_INTEL_SDW_ACPI=m
CONFIG_SND_SOF=m
CONFIG_SND_SOF_PCI=m
CONFIG_SND_SOF_INTEL_ICL=m

# RTW88 WiFi — bus-level parents MUST be set or sub-drivers get silently disabled
CONFIG_RTW88_CORE=m
CONFIG_RTW88_PCI=m
CONFIG_RTW88_USB=m
CONFIG_RTW88_SDIO=m
CONFIG_RTW88_8821C=m
CONFIG_RTW88_8821CE=m
CONFIG_RTW88_8822BE=m
CONFIG_RTW88_8822CE=m
CONFIG_RTW88_8723DE=m

# RTW89 WiFi (newer Realtek chips)
CONFIG_RTW89=m
CONFIG_RTW89_CORE=m
CONFIG_RTW89_PCI=m

# Intel GPU force probe
CONFIG_DRM_I915_FORCE_PROBE="*"
CONFIG_SND_HDA_I915=y

# Intel LPSS (I2C touchpad on modern laptops)
CONFIG_X86_INTEL_LPSS=y
CONFIG_MFD_INTEL_LPSS=m
CONFIG_MFD_INTEL_LPSS_ACPI=m
CONFIG_MFD_INTEL_LPSS_PCI=m
CONFIG_PINCTRL_INTEL=y
CONFIG_I2C_DESIGNWARE_CORE=m
CONFIG_I2C_DESIGNWARE_PLATFORM=m
CONFIG_I2C_HID_ACPI=m

# InterGenOS Kernel Config Fragment: IoT & Smart Home
# Covers Zigbee, serial adapters, sensor buses, containers for Home Assistant
#
# Most smart home protocols (Z-Wave, Matter/Thread) are userspace-only
# and don't need kernel support. The kernel provides the transport layer.

# --- USB-to-Serial Adapters (ESSENTIAL for IoT) ---
# These cover 95%+ of Zigbee sticks, microcontrollers, and IoT adapters
CONFIG_USB_SERIAL=m
CONFIG_USB_SERIAL_FTDI_SIO=m
CONFIG_USB_SERIAL_CP210X=m
CONFIG_USB_SERIAL_CH341=m
CONFIG_USB_SERIAL_PL2303=m
CONFIG_USB_ACM=m

# Raw USB access for libusb-based tools
CONFIG_USB_USBFS=y

# --- Sensor Buses ---

# I2C (temperature, humidity, pressure sensors, OLED displays)
CONFIG_I2C=y
CONFIG_I2C_CHARDEV=m
CONFIG_I2C_GPIO=m
CONFIG_I2C_MUX=m

# SPI (higher-speed sensors, displays, LoRa modules)
CONFIG_SPI=y
CONFIG_SPI_SPIDEV=m
CONFIG_SPI_GPIO=m

# GPIO (direct pin control for relays, LEDs, buttons)
CONFIG_GPIOLIB=y
CONFIG_GPIO_CHARDEV=y

# 1-Wire (Dallas/Maxim temperature sensors — DS18B20 etc.)
CONFIG_W1=m
CONFIG_W1_GPIO=m
CONFIG_W1_THERM=m
CONFIG_W1_SLAVE_DS2413=m

# --- Wireless IoT Protocols ---

# IEEE 802.15.4 / 6LoWPAN (Zigbee transport layer)
CONFIG_IEEE802154=m
CONFIG_IEEE802154_6LOWPAN=m
CONFIG_MAC802154=m
CONFIG_6LOWPAN=m

# NFC (future-proofing for smart tags, device pairing)
CONFIG_NFC=m
CONFIG_NFC_DIGITAL=m
CONFIG_NFC_PN533=m

# CAN Bus (automotive/industrial IoT)
CONFIG_CAN=m
CONFIG_CAN_RAW=m
CONFIG_CAN_BCM=m
CONFIG_CAN_GW=m

# --- Container Support (Home Assistant, Docker, Podman) ---
# Note: CGROUPS and NAMESPACES are in 10-systemd.config
# These add the container-specific pieces

CONFIG_OVERLAY_FS=m
CONFIG_BRIDGE=m
CONFIG_VXLAN=m
CONFIG_VETH=m
CONFIG_NETFILTER_XT_MATCH_CONNTRACK=m
CONFIG_NETFILTER_XT_MATCH_ADDRTYPE=m
CONFIG_NF_NAT_MASQUERADE=m
